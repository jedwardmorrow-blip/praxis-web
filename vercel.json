{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/az-ice-arcadia",
      "destination": "/az-ice-arcadia/index.html"
    },
    {
      "source": "/aspire/assessment-language-validation",
      "destination": "/aspire/assessment-language-validation.html"
    },
    {
      "source": "/world-model",
      "destination": "/world-model.html"
    },
    {
      "source": "/world-model/3d",
      "destination": "/world-model-3d.html"
    },
    {
      "source": "/system",
      "destination": "/system.html"
    },
    {
      "source": "/artifacts",
      "destination": "/artifacts.html"
    },
    {
      "source": "/animation",
      "destination": "/animation.html"
    },
    {
      "source": "/sites/:slug",
      "destination": "/sites/:slug/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/atom",
      "destination": "/world-model",
      "permanent": true
    },
    {
      "source": "/brand",
      "destination": "/system",
      "permanent": true
    },
    {
      "source": "/3d",
      "destination": "/world-model/3d",
      "permanent": true
    },
    {
      "source": "/gopraxis-v4-motion",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/concept-5-system",
      "destination": "/system",
      "permanent": true
    },
    {
      "source": "/system-artifacts",
      "destination": "/artifacts",
      "permanent": true
    },
    {
      "source": "/signature-animation",
      "destination": "/animation",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/aspire/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        },
        {
          "key": "Cache-Control",
          "value": "private, no-store"
        }
      ]
    },
    {
      "source": "/az-ice-arcadia",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        },
        {
          "key": "Cache-Control",
          "value": "private, no-store"
        }
      ]
    },
    {
      "source": "/az-ice-arcadia/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        },
        {
          "key": "Cache-Control",
          "value": "private, no-store"
        }
      ]
    },
    {
      "source": "/assets/(.*).svg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(favicon|apple-touch-icon).svg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/sites/:path*",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        },
        {
          "key": "Cache-Control",
          "value": "private, no-store"
        }
      ]
    }
  ]
}
